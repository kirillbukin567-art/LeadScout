# LeadScout — пример файла окружения (см. ТЗ §11).
# Скопируйте в .env и заполните реальными значениями.
# .env НИКОГДА не коммитится в git (см. .gitignore) — все секреты только отсюда,
# никогда не хардкодятся в коде (обязательное правило проекта).

# --- Claude / Anthropic ---------------------------------------------------
# Ключ Anthropic API. Скоринг лидов — claude-haiku, черновики/реплики — claude-sonnet.
ANTHROPIC_API_KEY=

# --- Telegram (Telethon, MTProto) ------------------------------------------
# API ID/Hash выдаются на https://my.telegram.org
TG_API_ID=
TG_API_HASH=
# Имя файла сессии мониторингового аккаунта (только чтение, вступление в чаты вручную)
TG_SESSION_MONITOR=monitor
# Имя файла сессии аккаунта-отправителя (Sender), отдельного от мониторингового
# и от личного основного аккаунта оператора (см. §10 ТЗ)
TG_SESSION_SENDER=sender

# --- Управляющий Telegram-бот (aiogram, Bot API) ---------------------------
# Токен бота от @BotFather
CONTROL_BOT_TOKEN=
# Telegram user_id оператора — только ему бот присылает карточки лидов и отвечает на команды
OPERATOR_TG_ID=

# --- Reddit (PRAW) -----------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- YouTube Data API v3 -------------------------------------------------
YOUTUBE_API_KEY=

# --- VK API (v1.1) -------------------------------------------------------
VK_TOKEN=

# ============================================================================
# Необязательные переменные — не входят в §11 ТЗ, но читаются core/settings.py.
# У всех есть безопасные значения по умолчанию, переопределяйте при необходимости.
# ============================================================================

# Путь к SQLite БД (см. §6 ТЗ), при росте — миграция на Postgres
# DATABASE_URL=sqlite:///data/leadscout.db

# Уровень логирования loguru: TRACE|DEBUG|INFO|WARNING|ERROR|CRITICAL
# LOG_LEVEL=INFO

# Стартовый режим работы бота: m1 (радар) | m2 (копайлот) | m3 (автодиалог, per-dialogue)
# DEFAULT_MODE=m1

# Порог score для отправки карточки оператору (§8.1 ТЗ, настраивается также /threshold)
# SCORE_THRESHOLD=55

# Часовой пояс оператора по умолчанию (для утреннего дайджеста, §12 ТЗ)
# OPERATOR_TIMEZONE=Europe/Moscow
